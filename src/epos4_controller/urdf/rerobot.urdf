<?xml version="1.0"?>
<robot name="rerobot">

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry>
        <box size="0.50 0.35 0.10"/>
      </geometry>
      <material name="body_gray">
        <color rgba="0.4 0.4 0.4 1.0"/>
      </material>
    </visual>
  </link>

  <link name="m1_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.05"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <link name="m2_wheel_link">
    <visual>
      <origin xyz="0 0 0" rpy="1.5707963267948966 0 0"/>
      <geometry>
        <cylinder radius="0.075" length="0.05"/>
      </geometry>
      <material name="wheel_black">
        <color rgba="0.1 0.1 0.1 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="m1_wheel" type="continuous">
    <parent link="base_link"/>
    <child  link="m1_wheel_link"/>
    <origin xyz="0 0.205 0.075" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <joint name="m2_wheel" type="continuous">
    <parent link="base_link"/>
    <child  link="m2_wheel_link"/>
    <origin xyz="0 -0.205 0.075" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <!-- claude: 2D LiDAR (簡易ジオメトリ) — 車軸中心 (z=0.075) の 0.639 m 上 -->
  <link name="laser_frame">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.04"/>
      </geometry>
      <material name="lidar_blue">
        <color rgba="0.1 0.3 0.8 1.0"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="laser_frame"/>
    <origin xyz="0 0 0.714" rpy="0 0 0"/>
  </joint>

</robot>
